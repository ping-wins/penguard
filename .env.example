# FortiDashboard environment template.
#
# DO NOT use this file directly in production. Run
#   ./scripts/bootstrap-secrets.sh           (Linux / macOS / WSL)
#   ./scripts/bootstrap-secrets.ps1          (Windows PowerShell)
# to generate a real .env with strong per-deploy secrets. The BFF refuses
# to start when any of the values below still equal a dev default
# (see apps/api/app/core/config.py:DANGEROUS_DEFAULT_SECRETS).
#
# For local dev/test without rotating secrets, set FORTIDASHBOARD_MOCK_MODE=true.

# Shared local development
POSTGRES_USER=fortidashboard
POSTGRES_PASSWORD=fortidashboard
POSTGRES_DB=fortidashboard
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
API_HOST=http://localhost:8000
FRONTEND_URL=http://localhost:5173
FORTIDASHBOARD_API_PORT=8000
FORTIDASHBOARD_WEB_PORT=5173
FORTIDASHBOARD_KEYCLOAK_PORT=8080
FORTIDASHBOARD_POSTGRES_PORT=5432
FORTIDASHBOARD_REDIS_PORT=6379

# FastAPI backend
FORTIDASHBOARD_DATABASE_URL=postgresql+psycopg://fortidashboard:fortidashboard@localhost:5432/fortidashboard
# Replaced by bootstrap-secrets. Boot fails when these still match the dev default.
FORTIDASHBOARD_SECRET_KEY=change-me-in-local-env
FORTIDASHBOARD_TOKEN_ENCRYPTION_KEY=
FORTIDASHBOARD_MOCK_MODE=false
FORTIDASHBOARD_SESSION_COOKIE_NAME=fortidashboard_session
FORTIDASHBOARD_SESSION_COOKIE_SECURE=false
FORTIDASHBOARD_CSRF_COOKIE_NAME=fortidashboard_csrf
FORTIDASHBOARD_CSRF_HEADER_NAME=X-CSRF-Token
FORTIDASHBOARD_AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
FORTIDASHBOARD_AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Keycloak (bootstrap-secrets generates KC_BOOTSTRAP_ADMIN_PASSWORD and
# FORTIDASHBOARD_KEYCLOAK_CLIENT_SECRET; do not ship the dev values to prod).
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
# Host/non-Docker API default. Docker Compose overrides API-to-Keycloak traffic
# with FORTIDASHBOARD_KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080.
FORTIDASHBOARD_KEYCLOAK_BASE_URL=http://localhost:8080
FORTIDASHBOARD_KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080
FORTIDASHBOARD_KEYCLOAK_BROWSER_BASE_URL=http://localhost:8080
FORTIDASHBOARD_KEYCLOAK_REALM=fortidashboard
FORTIDASHBOARD_KEYCLOAK_CLIENT_ID=fortidashboard-bff
FORTIDASHBOARD_KEYCLOAK_CLIENT_SECRET=dev-client-secret
# Default is an inert tracked placeholder so Compose works on Linux/Windows
# before AD is configured. For real Kerberos SSO, set ./fortidashboard.keytab.
FORTIDASHBOARD_KEYTAB_PATH=./infra/keycloak/empty-keytab.placeholder

# Browser-facing SSO URLs
FORTIDASHBOARD_OIDC_ISSUER=http://localhost:8080/realms/fortidashboard
FORTIDASHBOARD_SSO_REDIRECT_URI=http://localhost:8000/api/auth/sso/kerberos/callback
FORTIDASHBOARD_SSO_POST_LOGIN_URL=http://localhost:5173/
FORTIDASHBOARD_SSO_FAILURE_REDIRECT_URL=http://localhost:5173/login

# SOC-lite services
FORTIDASHBOARD_SIEM_KOWALSKI_URL=http://siem-kowalski:8000
FORTIDASHBOARD_SOAR_SKIPPER_URL=http://soar-skipper:8000
FORTIDASHBOARD_XDR_RICO_URL=http://xdr-rico:8000
SIEM_KOWALSKI_DATABASE_URL=postgresql+psycopg://fortidashboard:fortidashboard@localhost:5432/fortidashboard
SOAR_SKIPPER_DATABASE_URL=postgresql+psycopg://fortidashboard:fortidashboard@localhost:5432/fortidashboard
XDR_RICO_DATABASE_URL=postgresql+psycopg://fortidashboard:fortidashboard@localhost:5432/fortidashboard

# Optional AD/Kerberos lab overrides. Keep KEYCLOAK_BASE_URL internal when
# running the API in Docker Compose; only browser-facing URLs switch hostnames.
# FORTIDASHBOARD_KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080
# FORTIDASHBOARD_KEYTAB_PATH=./fortidashboard.keytab
# FORTIDASHBOARD_KEYCLOAK_BROWSER_BASE_URL=http://fortidashboard.local:8080
# FORTIDASHBOARD_OIDC_ISSUER=http://fortidashboard.local:8080/realms/fortidashboard
# FORTIDASHBOARD_SSO_REDIRECT_URI=http://fortidashboard.local:8000/api/auth/sso/kerberos/callback
# FORTIDASHBOARD_SSO_POST_LOGIN_URL=http://fortidashboard.local:5173/
# FORTIDASHBOARD_SSO_FAILURE_REDIRECT_URL=http://fortidashboard.local:5173/login
