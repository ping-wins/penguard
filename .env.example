# Penguard environment template.
#
# DO NOT use this file directly in production. Run
#   ./scripts/bootstrap-secrets.sh           (Linux / macOS / WSL)
#   ./scripts/bootstrap-secrets.ps1          (Windows PowerShell)
# to generate a real .env with strong per-deploy secrets. The BFF refuses
# to start when any of the values below still equal a dev default
# (see apps/api/app/core/config.py:DANGEROUS_DEFAULT_SECRETS).
#
# For local dev/test without rotating secrets, set PENGUARD_MOCK_MODE=true.

# Shared local development
POSTGRES_USER=penguard
POSTGRES_PASSWORD=penguard
POSTGRES_DB=penguard
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
API_HOST=http://localhost:8000
FRONTEND_URL=http://localhost:5173
PENGUARD_API_PORT=8000
PENGUARD_WEB_PORT=5173
PENGUARD_KEYCLOAK_PORT=8080
PENGUARD_POSTGRES_PORT=5432
PENGUARD_REDIS_PORT=6379

# FastAPI backend
PENGUARD_DATABASE_URL=postgresql+psycopg://penguard:penguard@localhost:5432/penguard
# Replaced by bootstrap-secrets. Boot fails when these still match the dev default.
PENGUARD_SECRET_KEY=change-me-in-local-env
PENGUARD_TOKEN_ENCRYPTION_KEY=
PENGUARD_MOCK_MODE=false
PENGUARD_SESSION_COOKIE_NAME=penguard_session
PENGUARD_SESSION_COOKIE_SECURE=false
PENGUARD_SESSION_COOKIE_SAMESITE=lax
PENGUARD_SESSION_COOKIE_HTTPONLY=true
PENGUARD_CSRF_COOKIE_NAME=penguard_csrf
PENGUARD_CSRF_HEADER_NAME=X-CSRF-Token
PENGUARD_AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
PENGUARD_AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Keycloak (bootstrap-secrets generates KC_BOOTSTRAP_ADMIN_PASSWORD and
# PENGUARD_KEYCLOAK_CLIENT_SECRET; do not ship the dev values to prod).
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
# Host/non-Docker API default. Docker Compose overrides API-to-Keycloak traffic
# with PENGUARD_KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080.
PENGUARD_KEYCLOAK_BASE_URL=http://localhost:8080
PENGUARD_KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080
PENGUARD_KEYCLOAK_BROWSER_BASE_URL=http://localhost:8080
PENGUARD_KEYCLOAK_REALM=penguard
PENGUARD_KEYCLOAK_CLIENT_ID=penguard-bff
PENGUARD_KEYCLOAK_CLIENT_SECRET=dev-client-secret
PENGUARD_KEYCLOAK_VERIFY_SSL=false
# Default is an inert tracked placeholder so Compose works on Linux/Windows
# before AD is configured. For real Kerberos SSO, set ./penguard.keytab.
PENGUARD_KEYTAB_PATH=./infra/keycloak/empty-keytab.placeholder

# Browser-facing SSO URLs
PENGUARD_OIDC_ISSUER=http://localhost:8080/realms/penguard
PENGUARD_SSO_REDIRECT_URI=http://localhost:8000/api/auth/sso/kerberos/callback
PENGUARD_SSO_POST_LOGIN_URL=http://localhost:5173/
PENGUARD_SSO_FAILURE_REDIRECT_URL=http://localhost:5173/login

# SOC-lite services
PENGUARD_SIEM_KOWALSKI_URL=http://siem-kowalski:8000
PENGUARD_SOAR_SKIPPER_URL=http://soar-skipper:8000
PENGUARD_XDR_RICO_URL=http://xdr-rico:8000
PENGUARD_FORTIGATE_INGESTION_SCHEDULER_ENABLED=false
PENGUARD_FORTIGATE_INGESTION_SCHEDULER_TICK_SECONDS=10
PENGUARD_FORTIGATE_INGESTION_DEFAULT_INTERVAL_SECONDS=30
PENGUARD_FORTIGATE_INGESTION_MIN_INTERVAL_SECONDS=10
PENGUARD_FORTIGATE_INGESTION_MAX_INTERVAL_SECONDS=3600
# UDP syslog collector binds inside the API container. PUBLIC_HOST is the
# FortiGate-reachable host/IP; bootstrap scripts auto-detect a best-effort
# local LAN IP, but this template leaves it blank for portability.
PENGUARD_FORTIGATE_SYSLOG_COLLECTOR_HOST=0.0.0.0
PENGUARD_FORTIGATE_SYSLOG_COLLECTOR_PUBLIC_HOST=
PENGUARD_FORTIGATE_SYSLOG_COLLECTOR_PORT=5514
PENGUARD_ENABLE_LAB_DEMO_TOOLS=false
SIEM_KOWALSKI_DATABASE_URL=postgresql+psycopg://penguard:penguard@localhost:5432/penguard
SOAR_SKIPPER_DATABASE_URL=postgresql+psycopg://penguard:penguard@localhost:5432/penguard
XDR_RICO_DATABASE_URL=postgresql+psycopg://penguard:penguard@localhost:5432/penguard

# AI provider (used by ticket "Analyze" / "Suggest containment" and the sidebar
# chat). Default "scripted" needs no key and works offline. Set to "anthropic",
# "gemini" or "openai_compat" to call a real model.
#
# Compose forwards these vars to the api container via the `environment:` block;
# without that, Pydantic Settings inside the container falls back to scripted.
PENGUARD_AI_PROVIDER=scripted
PENGUARD_AI_API_KEY=
PENGUARD_AI_MODEL=
PENGUARD_AI_BASE_URL=

# Threat Intel enrichment for incidents and Sysmon-derived endpoint events.
# Leave the API key empty to keep the provider disabled. Never commit a real key.
PENGUARD_THREAT_INTEL_PROVIDER=virustotal
PENGUARD_THREAT_INTEL_CACHE_TTL_SECONDS=3600
PENGUARD_VIRUSTOTAL_API_KEY=
PENGUARD_VIRUSTOTAL_BASE_URL=https://www.virustotal.com
#
# --- Recipe: Google Gemini ---
# (key from https://aistudio.google.com/apikey — Gemini Pro UI sub is separate)
# Use PENGUARD_AI_PROVIDER=gemini, NOT openai_compat with the
# /v1beta/openai base URL — that shim drops fields and turns missing/invalid
# keys into 404/400 with misleading messages. See apps/api/app/ai/provider.py.
# PENGUARD_AI_PROVIDER=gemini
# PENGUARD_AI_API_KEY=AIza...
# PENGUARD_AI_MODEL=gemini-flash-latest
# PENGUARD_AI_BASE_URL=https://generativelanguage.googleapis.com
#
# --- Recipe: Anthropic Claude ---
# (key from https://console.anthropic.com — Claude Pro UI sub is separate)
# PENGUARD_AI_PROVIDER=anthropic
# PENGUARD_AI_API_KEY=sk-ant-...
# PENGUARD_AI_MODEL=claude-haiku-4-5-20251001
# PENGUARD_AI_BASE_URL=https://api.anthropic.com

# SOC push ingestion (FortiGate webhook → BFF → siem-kowalski).
# Replaces / complements the pull-based scheduler. Set a long random value and
# configure a matching shared secret in the FortiGate Automation Stitch.
# Endpoint: POST {API_HOST}/api/soc/ingest/fortigate
# Headers:  Authorization: Bearer <token>
#           X-Penguard-Integration-Id: <FORTIGATE_INTEGRATION_ID>
# Empty value disables the endpoint (returns 503).
#
# --- Recipe: FortiGate Automation Stitch for scan/anomaly or admin login fail ---
# 1. System > Automation > Trigger: "Log" filter for IPS/anomaly/scan, or
#    event/system log id 0100040704 "admin-login-failed".
# 2. Action: "Webhook". URL: https://<bff-host>/api/soc/ingest/fortigate
#    Method: POST. Headers: Authorization: Bearer <PENGUARD_SOC_INGEST_TOKEN>
#    and X-Penguard-Integration-Id: <FORTIGATE_INTEGRATION_ID>
#    Body (JSON, use FortiGate %%log.field%% substitutions):
#    {
#      "logid": "%%log.logid%%",
#      "type": "%%log.type%%",
#      "subtype": "%%log.subtype%%",
#      "action": "%%log.action%%",
#      "status": "%%log.status%%",
#      "level": "%%log.level%%",
#      "srcip": "%%log.srcip%%",
#      "dstip": "%%log.dstip%%",
#      "user": "%%log.user%%",
#      "msg": "%%log.msg%%",
#      "eventtime": "%%log.eventtime%%"
#    }
# 3. Stitch: bind trigger + action. Enable. Scan/anomaly events push live
#    immediately; brute-force/admin-login-failed bursts are aggregated.
PENGUARD_SOC_INGEST_TOKEN=

# Marketplace add-on packages (Plan A).
# Read-only GitHub token for fetching ping-wins/penguard-addons
# (catalog.json + tarballs). Required when the registry repo is private.
# Compose maps this into PENGUARD_MARKETPLACE_GH_TOKEN inside the API
# container so Pydantic Settings picks it up.
MARKETPLACE_GH_TOKEN=
# Override the registry repo if you fork/mirror:
# MARKETPLACE_REGISTRY_REPO=ping-wins/penguard-addons

# Optional AD/Kerberos lab overrides. Keep KEYCLOAK_BASE_URL internal when
# running the API in Docker Compose; only browser-facing URLs switch hostnames.
# PENGUARD_KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080
# PENGUARD_KEYTAB_PATH=./penguard.keytab
# PENGUARD_KEYCLOAK_BROWSER_BASE_URL=http://penguard.local:8080
# PENGUARD_OIDC_ISSUER=http://penguard.local:8080/realms/penguard
# PENGUARD_SSO_REDIRECT_URI=http://penguard.local:8000/api/auth/sso/kerberos/callback
# PENGUARD_SSO_POST_LOGIN_URL=http://penguard.local:5173/
# PENGUARD_SSO_FAILURE_REDIRECT_URL=http://penguard.local:5173/login
