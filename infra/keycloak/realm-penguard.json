{
  "realm": "penguard",
  "enabled": true,
  "displayName": "Penguard",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "analyst",
        "description": "Default SOC analyst role"
      },
      {
        "name": "admin",
        "description": "Penguard administrator role"
      }
    ]
  },
  "clients": [
    {
      "clientId": "penguard-bff",
      "name": "Penguard BFF",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "dev-client-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:8000/api/auth/sso/kerberos/callback",
        "http://penguard.local:8000/api/auth/sso/kerberos/callback",
        "http://api:8000/api/auth/sso/kerberos/callback"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:8000",
        "http://penguard.local:5173",
        "http://penguard.local:8000"
      ]
    }
  ],
  "components": {
    "org.keycloak.storage.UserStorageProvider": [
      {
        "name": "kerberos-penguard",
        "providerId": "kerberos",
        "subComponents": {},
        "config": {
          "priority": ["0"],
          "enabled": ["true"],
          "kerberosRealm": ["PENGUARD.LOCAL"],
          "serverPrincipal": ["HTTP/penguard.local@PENGUARD.LOCAL"],
          "keyTab": ["/opt/keycloak/conf/penguard.keytab"],
          "debug": ["false"],
          "allowPasswordAuthentication": ["false"],
          "updateProfileFirstLogin": ["false"],
          "cachePolicy": ["DEFAULT"],
          "editMode": ["UNSYNCED"]
        }
      }
    ]
  },
  "users": [
    {
      "username": "service-account-penguard-bff",
      "enabled": true,
      "serviceAccountClientId": "penguard-bff",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users"]
      }
    },
    {
      "username": "analyst@example.com",
      "email": "analyst@example.com",
      "firstName": "SOC",
      "lastName": "Analyst",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "correct-horse-battery-staple",
          "temporary": false
        }
      ],
      "realmRoles": ["analyst"]
    },
    {
      "username": "admin@example.com",
      "email": "admin@example.com",
      "firstName": "SOC",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "correct-horse-battery-staple",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    }
  ]
}
